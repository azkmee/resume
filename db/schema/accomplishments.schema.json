{
  "bsonType": "object",
  "title": "accomplishments",
  "description": "A single STAR-format win. Migrated from accomplishments-log.md.",
  "required": ["slug", "title", "star", "status", "provenance"],
  "properties": {
    "slug": { "bsonType": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "experienceId": { "bsonType": ["objectId", "null"] },
    "experienceSlug": { "bsonType": ["string", "null"] },
    "title": { "bsonType": "string" },
    "date": {
      "bsonType": ["object", "null"],
      "properties": {
        "raw": { "bsonType": ["string", "null"] },
        "iso": { "bsonType": ["string", "null"] },
        "approximate": { "bsonType": "bool" }
      }
    },
    "star": {
      "bsonType": "object",
      "required": ["situation", "task", "result"],
      "properties": {
        "situation": { "bsonType": "string" },
        "task": { "bsonType": "string" },
        "action": { "bsonType": "array", "items": { "bsonType": "string" } },
        "result": { "bsonType": "array", "items": { "bsonType": "string" } }
      }
    },
    "metrics": {
      "bsonType": "array",
      "items": {
        "bsonType": "object",
        "required": ["label"],
        "properties": {
          "label": { "bsonType": "string" },
          "value": { "bsonType": ["double", "int", "long", "null"] },
          "unit": { "bsonType": ["string", "null"] }
        }
      }
    },
    "resumeBullets": {
      "bsonType": "array",
      "items": {
        "bsonType": "object",
        "required": ["text"],
        "properties": {
          "variant": { "enum": ["combined", "split", "default", null] },
          "text": { "bsonType": "string" }
        }
      }
    },
    "tags": { "bsonType": "array", "items": { "bsonType": "string" } },
    "featured": { "bsonType": "bool" },
    "order": { "bsonType": ["int", "long", "double"] },
    "visibility": { "enum": ["public", "unlisted", "private"] },
    "status": { "enum": ["draft", "in_review", "needs_review", "published", "archived"] },
    "provenance": {
      "bsonType": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["claude", "human", "import"] },
        "model": { "bsonType": ["string", "null"] },
        "sourcePrompt": { "bsonType": ["string", "null"] },
        "sourceRef": { "bsonType": ["string", "null"] },
        "generatedAt": { "bsonType": ["date", "null"] },
        "reviewedBy": { "bsonType": ["string", "null"] },
        "reviewedAt": { "bsonType": ["date", "null"] }
      }
    },
    "createdAt": { "bsonType": "date" },
    "updatedAt": { "bsonType": "date" },
    "publishedAt": { "bsonType": ["date", "null"] },
    "version": { "bsonType": ["int", "long", "double"] }
  }
}
