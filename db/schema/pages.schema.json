{
  "bsonType": "object",
  "title": "pages",
  "description": "Flexible block-based content for arbitrary site sections (about, now, uses, contact). Reuses the blog block model.",
  "required": ["slug", "title", "body", "status", "provenance"],
  "properties": {
    "slug": { "bsonType": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "bsonType": "string" },
    "kind": { "enum": ["page", "section"] },
    "placement": { "enum": ["home", "about", "now", "uses", "contact", "footer", "custom"] },
    "body": {
      "bsonType": "object",
      "required": ["format", "blocks"],
      "properties": {
        "format": { "enum": ["blocks", "markdown"] },
        "markdown": { "bsonType": ["string", "null"] },
        "blocks": {
          "bsonType": "array",
          "items": {
            "bsonType": "object",
            "required": ["type"],
            "properties": {
              "key": { "bsonType": "string" },
              "order": { "bsonType": ["int", "long", "double"] },
              "type": {
                "enum": ["markdown", "html", "image", "gallery", "diagram", "code", "callout", "embed", "quote", "divider"]
              }
            }
          }
        }
      }
    },
    "tags": { "bsonType": "array", "items": { "bsonType": "string" } },
    "featured": { "bsonType": "bool" },
    "order": { "bsonType": ["int", "long", "double"] },
    "visibility": { "enum": ["public", "unlisted", "private"] },
    "status": { "enum": ["draft", "in_review", "needs_review", "published", "archived"] },
    "seo": {
      "bsonType": ["object", "null"],
      "properties": {
        "title": { "bsonType": ["string", "null"] },
        "description": { "bsonType": ["string", "null"] },
        "ogImageId": { "bsonType": ["objectId", "null"] }
      }
    },
    "provenance": {
      "bsonType": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["claude", "human", "import"] },
        "model": { "bsonType": ["string", "null"] },
        "sourceRef": { "bsonType": ["string", "null"] },
        "reviewedBy": { "bsonType": ["string", "null"] }
      }
    },
    "createdAt": { "bsonType": "date" },
    "updatedAt": { "bsonType": "date" },
    "publishedAt": { "bsonType": ["date", "null"] },
    "version": { "bsonType": ["int", "long", "double"] }
  }
}
