{
  "bsonType": "object",
  "title": "feed",
  "description": "The 'Recently' broadcast feed (Home). Short, dated status updates / changelog entries.",
  "required": ["slug", "date", "body", "status", "provenance"],
  "properties": {
    "slug": { "bsonType": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "date": { "bsonType": "string", "description": "Display date, e.g. '2026-05-22'." },
    "kind": {
      "enum": ["promotion", "system", "build", "ship", "talk", "read", "other"],
      "description": "Drives the coloured tag chip."
    },
    "label": { "bsonType": ["string", "null"], "description": "Override tag text if different from kind." },
    "body": { "bsonType": "string", "description": "One-line update; may contain light inline markup." },
    "link": { "bsonType": ["string", "null"] },
    "derivedFrom": {
      "bsonType": "array",
      "items": { "bsonType": "string" },
      "description": "accomplishments.slug[] / case_studies.slug[] / teardowns.slug[] this references."
    },
    "pinned": { "bsonType": "bool" },
    "tags": { "bsonType": "array", "items": { "bsonType": "string" } },
    "order": { "bsonType": ["int", "long", "double"] },
    "visibility": { "enum": ["public", "unlisted", "private"] },
    "status": { "enum": ["draft", "in_review", "needs_review", "published", "archived"] },
    "provenance": {
      "bsonType": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["claude", "human", "import"] },
        "model": { "bsonType": ["string", "null"] },
        "sourcePrompt": { "bsonType": ["string", "null"] },
        "sourceRef": { "bsonType": ["string", "null"] },
        "generatedAt": { "bsonType": ["date", "null"] },
        "reviewedBy": { "bsonType": ["string", "null"] },
        "reviewedAt": { "bsonType": ["date", "null"] }
      }
    },
    "createdAt": { "bsonType": "date" },
    "updatedAt": { "bsonType": "date" },
    "publishedAt": { "bsonType": ["date", "null"] },
    "version": { "bsonType": ["int", "long", "double"] }
  }
}
