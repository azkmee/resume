{
  "bsonType": "object",
  "title": "case_studies",
  "description": "Flagship professional work (Work page, CS-xx). Distinct from side projects. Often derived from accomplishments.",
  "required": ["slug", "title", "status", "provenance"],
  "properties": {
    "slug": { "bsonType": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "code": { "bsonType": ["string", "null"], "description": "Display id like 'CS-01'." },
    "title": { "bsonType": "string" },
    "pitch": { "bsonType": ["string", "null"], "description": "One- or two-line summary shown on the card." },
    "period": {
      "bsonType": ["object", "null"],
      "properties": {
        "start": { "bsonType": ["string", "null"] },
        "end": { "bsonType": ["string", "null"] }
      }
    },
    "projectStatus": { "enum": ["shipped", "wip", "archived", "maintained", null] },
    "stack": { "bsonType": "array", "items": { "bsonType": "string" } },
    "result": {
      "bsonType": "array",
      "description": "Headline outcomes, e.g. {label:'precision', value:99.4, unit:'%'}.",
      "items": {
        "bsonType": "object",
        "required": ["label"],
        "properties": {
          "label": { "bsonType": "string" },
          "value": { "bsonType": ["double", "int", "long", "string", "null"] },
          "unit": { "bsonType": ["string", "null"] }
        }
      }
    },
    "experienceSlug": { "bsonType": ["string", "null"], "description": "-> experiences.slug it belongs to." },
    "derivedFrom": {
      "bsonType": "array",
      "items": { "bsonType": "string" },
      "description": "accomplishments.slug[] this write-up was distilled from."
    },
    "highlights": { "bsonType": "array", "items": { "bsonType": "string" } },
    "body": {
      "bsonType": ["object", "null"],
      "description": "Optional expanded write-up; same block model as teardowns/blog_posts.",
      "properties": {
        "format": { "enum": ["blocks", "markdown"] },
        "markdown": { "bsonType": ["string", "null"] },
        "blocks": { "bsonType": "array" }
      }
    },
    "links": {
      "bsonType": "array",
      "items": {
        "bsonType": "object",
        "required": ["type", "url"],
        "properties": {
          "type": { "enum": ["repo", "demo", "case_study", "docs", "video", "article", "other"] },
          "label": { "bsonType": ["string", "null"] },
          "url": { "bsonType": "string" }
        }
      }
    },
    "coverMediaId": { "bsonType": ["objectId", "null"] },
    "gallery": { "bsonType": "array", "items": { "bsonType": "objectId" } },
    "tags": { "bsonType": "array", "items": { "bsonType": "string" } },
    "featured": { "bsonType": "bool" },
    "order": { "bsonType": ["int", "long", "double"] },
    "visibility": { "enum": ["public", "unlisted", "private"] },
    "status": { "enum": ["draft", "in_review", "needs_review", "published", "archived"] },
    "seo": {
      "bsonType": ["object", "null"],
      "properties": {
        "title": { "bsonType": ["string", "null"] },
        "description": { "bsonType": ["string", "null"] },
        "ogImageId": { "bsonType": ["objectId", "null"] }
      }
    },
    "provenance": {
      "bsonType": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["claude", "human", "import"] },
        "model": { "bsonType": ["string", "null"] },
        "sourcePrompt": { "bsonType": ["string", "null"] },
        "sourceRef": { "bsonType": ["string", "null"] },
        "generatedAt": { "bsonType": ["date", "null"] },
        "reviewedBy": { "bsonType": ["string", "null"] },
        "reviewedAt": { "bsonType": ["date", "null"] }
      }
    },
    "createdAt": { "bsonType": "date" },
    "updatedAt": { "bsonType": "date" },
    "publishedAt": { "bsonType": ["date", "null"] },
    "version": { "bsonType": ["int", "long", "double"] }
  }
}
